{
    "name": "example-graph",
    "version": "0.0.1",
    "description": "A starter template for creating a LangGraph workflow.",
    "packageManager": "bun@1.3.9",
    "main": "my_app/graph.ts",
    "author": "Your Name",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test": "vitest run --mode unit",
        "test:int": "vitest run --mode integration",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src",
        "lint:langgraph-json": "node scripts/checkLanggraphPaths.js",
        "lint:all": "bun run lint && bun run lint:langgraph-json && bun run format:check",
        "test:all": "bun run test && bun run test:int && bun run lint:all",
        "prepare": "husky"
    },
    "dependencies": {
        "@commitlint/config-conventional": "^20.5.0",
        "@langchain/core": "^1.1.36",
        "@langchain/langgraph": "^1.2.5",
        "husky": "^9.1.7",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@tsconfig/recommended": "^1.0.13",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8",
        "dotenv": "^17.3.1",
        "eslint": "^8.41.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-no-instanceof": "^1.0.1",
        "eslint-plugin-prettier": "^4.2.1",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    }
}
