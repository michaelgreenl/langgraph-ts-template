{
    "name": "langgraph-ts-template",
    "version": "0.5.0",
    "description": "A starter template for creating a LangGraph workflow.",
    "packageManager": "bun@1.3.9",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "author": "michaelgreenl",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./config": {
            "types": "./dist/config.d.ts",
            "import": "./dist/config.js",
            "default": "./dist/config.js"
        },
        "./scaffold": {
            "import": "./dist/scaffold/index.js",
            "types": "./dist/scaffold/index.d.ts"
        },
        "./templates": {
            "types": "./dist/templates/index.d.ts",
            "import": "./dist/templates/index.js",
            "default": "./dist/templates/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "src/scaffold/assets",
        "src/templates/defaults",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist",
        "test": "vitest run --mode unit",
        "test:int": "vitest run --mode integration",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "lint": "eslint src",
        "lint:all": "bun run lint && bun run format:check",
        "test:all": "bun run test && bun run test:int && bun run lint:all",
        "release": "semantic-release",
        "hooks": "husky"
    },
    "dependencies": {
        "@langchain/core": "^1.1.40",
        "@langchain/langgraph": "^1.2.8",
        "@langchain/openai": "^1.4.1",
        "nunjucks": "^3.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@tsconfig/recommended": "^1.0.13",
        "@types/node": "^24.12.2",
        "@types/nunjucks": "^3.2.6",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "conventional-changelog-conventionalcommits": "^9.3.1",
        "dotenv": "^17.4.2",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^8.10.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-no-instanceof": "^1.0.1",
        "eslint-plugin-prettier": "^4.2.5",
        "husky": "^9.1.7",
        "prettier": "^3.8.3",
        "semantic-release": "^25.0.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.4"
    }
}
