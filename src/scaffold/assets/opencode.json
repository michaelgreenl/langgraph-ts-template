{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "planner",
    "agent": {
        "planner": {
            "mode": "primary",
            "description": "Planning-only agent that writes initiative plans and phase tasks docs after clearing assumptions",
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
            "prompt": "__PLANNER_PROMPT__",
            "tools": {
                "question": true,
                "websearch": true
            },
            "permission": {
                "edit": "allow",
                "task": {
                    "explore": "allow",
                    "general": "allow"
                }
            }
        },
        "manager": {
            "mode": "primary",
            "description": "Executes a phase tasks.md step by step using coder subagents, validates results, commits clean steps",
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
            "prompt": "__MANAGER_PROMPT__",
            "permission": {
                "edit": "allow",
                "bash": "allow",
                "task": {
                    "*": "deny",
                    "coder": "allow",
                    "explore": "allow",
                    "general": "allow"
                }
            }
        },
        "coder": {
            "mode": "subagent",
            "hidden": true,
            "description": "TDD-focused implementor dispatched by the manager for a specific tasks.md step",
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
            "prompt": "__CODER_PROMPT__",
            "permission": {
                "edit": "allow",
                "bash": "allow"
            }
        }
    }
}
